# ===========================================================
#  모의투자(Paper) 환경
#  도메인: https://openapivts.koreainvestment.com:29443
#
#    cp env/.env.paper.example env/.env.paper
#  그리고 아래 값을 모의투자 전용 앱키/시크릿/계좌로 채우세요.
#  (모의투자 앱키는 실전과 다릅니다. KIS Developers 모의투자 메뉴에서 별도 발급)
# ===========================================================

KIS_APP_KEY=여기에_모의투자_앱키
KIS_APP_SECRET=여기에_모의투자_앱시크릿
KIS_ACCOUNT=00000000-01     # 계좌번호 8자리-상품코드 2자리
